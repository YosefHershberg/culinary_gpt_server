FROM node:22-alpine

WORKDIR /usr/src/app

# Install dependencies separately so they cache between source changes
COPY package*.json ./
RUN npm install

# Copy the rest of the source. In dev this is overlaid by a bind mount,
# but we still copy so the image is usable without compose.
COPY . .

# Generate Prisma client (src/generated/prisma is gitignored)
RUN npx prisma generate

EXPOSE 5000

# nodemon + ts-node, watches src/ and restarts on change
CMD ["npm", "run", "dev"]
